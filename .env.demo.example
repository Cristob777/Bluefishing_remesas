# ─── Supabase DEMO ──────────────────────────────────────────────
# Fuente: https://vxjryalvbtpczpfzkiyt.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Fuente: Supabase Dashboard → Project Settings → API → "Publishable" key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Fuente: Supabase Dashboard → Project Settings → API → "anon public" (legacy)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fuente: Supabase Dashboard → Project Settings → API → "service_role" (legacy)
# ⚠ SECRETO — nunca exponer al browser — solo pegar en Vercel Dashboard
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic ──────────────────────────────────────────────────
# Tu API key existente
ANTHROPIC_API_KEY=

# ─── App URL ────────────────────────────────────────────────────
# URL del deploy demo en Vercel (ej. https://remesaai-demo.vercel.app)
NEXTAUTH_URL=
NEXT_PUBLIC_APP_URL=

# ─── Secrets (generar con: openssl rand -hex 32) ────────────────
WEBHOOK_SECRET=
CRON_SECRET=
