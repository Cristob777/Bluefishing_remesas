# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key
# Service role key — solo server-side, NUNCA browser (sin NEXT_PUBLIC_)
# Obtener de: supabase.com → proyecto → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role_key

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── CMF Chile API (público, sin key obligatoria) ───────────
CMF_API_KEY=

# ─── Bsale ──────────────────────────────────────────────────
BSALE_TOKEN=your-bsale-access-token

# ─── Webhook ────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-to-a-long-random-secret

# ─── IMAP (correos operacionales) ───────────────────────────
IMAP_HOST=mail.tudominio.cl
IMAP_PORT=993
IMAP_USER_SEBASTIAN=sebastian.caceres@bluefishing.cl
IMAP_PASS_SEBASTIAN=
IMAP_USER_HECTOR=hector@bluefishing.cl
IMAP_PASS_HECTOR=

# ─── Email security ─────────────────────────────────────────
# Dominios permitidos para webhook (comma-separated, ej: gmail.com,agensa.cl,amigoscn.com)
ALLOWED_EMAIL_DOMAINS=
# Secret para Vercel Cron (generar con: openssl rand -base64 32)
CRON_SECRET=

# ─── Operational data (never hardcode in source) ────────────
# Company
COMPANY_NAME=
COMPANY_DISPLAY=BLUEFISHING.CL
# Customs agency
CUSTOMS_AGENCY_EMAIL=
CUSTOMS_AGENCY_NAME=
CUSTOMS_AGENCY_RUT=
CUSTOMS_AGENCY_BANK_ACCOUNTS=
# Internal emails — comma-separated for RBAC (no hardcoding in source)
OWNER_EMAILS=
FINANCE_EMAILS=
# Display names for email classifier prompt
OWNER_NAME=
FINANCE_NAME=
# Comma-separated supplier names for classifier
SUPPLIER_NAMES=
# Suppliers
SUPPLIER_CHINA_NAME=
SUPPLIER_CHINA_EMAIL=
SUPPLIER_JAPAN1_NAME=
SUPPLIER_JAPAN2_NAME=
