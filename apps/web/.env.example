# ════════════════════════════════════════════════════════════
# Import Workflow Agents — Environment Variables
# Copy to .env.local and fill in your values.
# Full setup guide: GET /api/setup/instructions (requires CRON_SECRET)
# ════════════════════════════════════════════════════════════

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key
# Service role — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role_key

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── App URL ────────────────────────────────────────────────
NEXTAUTH_URL=https://your-deployment.vercel.app

# Public URL of this deployment — used by lib/auth.ts to build ALLOWED_ORIGINS
# (the set of origins allowed in the CSRF check for cookie-authenticated mutations).
# In Vercel: set to your production domain, e.g. https://remesaai.vercel.app
# If absent, same-host requests still pass (host comparison); only cross-domain
# scenarios (preview → prod) require this to be set.
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# ─── CORS allowed origins ────────────────────────────────────
# Comma-separated list of origins permitted for cross-site mutation requests.
# Include every Vercel deployment URL that will POST to this app.
# Example: https://myapp.vercel.app,https://myapp-preview.vercel.app
ALLOWED_ORIGINS=

# ─── Secrets ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=
CRON_SECRET=

# ─── Gmail — Ops Inbox Pattern (recommended) ────────────────
#
# RECOMMENDED SETUP FOR ANY IMPORTING COMPANY:
# 1. Create one dedicated Gmail account: ops@yourcompany.com
# 2. Connect it via OAuth:
#    GET /api/gmail-auth?account=ops  (with Authorization: Bearer CRON_SECRET)
# 3. Each stakeholder imports forwarding filters:
#    GET /api/setup/gmail-filters?forward_to=ops@yourcompany.com
#    → Import the downloaded XML in Gmail Settings → Filters
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN_OPS=    # Primary ops inbox (connect via /api/gmail-auth?account=ops)
GMAIL_EMAIL_OPS=            # Email address of ops inbox (for logging)

# ─── Gmail — Additional accounts (optional) ─────────────────
# Up to 8 extra monitored inboxes. Add _2, _3... as needed.
GMAIL_REFRESH_TOKEN_ACCOUNT_1=
GMAIL_EMAIL_ACCOUNT_1=
GMAIL_LABEL_ACCOUNT_1=      # Label assigned to emails from this account (e.g. "owner")

# ─── Gmail — Legacy named slots (backwards compatibility) ────
GMAIL_REFRESH_TOKEN_SEBASTIAN=
GMAIL_REFRESH_TOKEN_HECTOR=

# ─── Email security ─────────────────────────────────────────
# Comma-separated allowed sender domains (leave empty = allow all during observation)
# Example: gmail.com,customsagency.cl,supplier.com,yourcompany.cl
ALLOWED_EMAIL_DOMAINS=

# ─── Operational data (never hardcode in source) ────────────

# Company
COMPANY_NAME=
COMPANY_DISPLAY=

# Internal people — comma-separated emails for RBAC
OWNER_EMAILS=
FINANCE_EMAILS=
OWNER_NAME=
FINANCE_NAME=

# Customs agency
CUSTOMS_AGENCY_EMAIL=
CUSTOMS_AGENCY_NAME=

# Suppliers — used by email classifier and Gmail filter generator
SUPPLIER_NAMES=                  # Comma-separated names (e.g. "Amigos Company,Meiho,Varivas")
SUPPLIER_EMAIL_1=                # First supplier email (add _2, _3... for more)
SUPPLIER_EMAIL_2=
SUPPLIER_EMAIL_3=

# ─── CMF Chile FX API (public, no key required) ─────────────
CMF_API_KEY=

# ─── Bsale ERP ──────────────────────────────────────────────
BSALE_TOKEN=

# ─── IMAP (alternative to Gmail API — not recommended for cloud) ──
# Note: Direct IMAP connections from Vercel are blocked by Gmail.
# Use the Gmail API (Ops Inbox pattern above) instead.
IMAP_HOST=
IMAP_PORT=993
IMAP_USER_ACCOUNT_1=
IMAP_PASS_ACCOUNT_1=
